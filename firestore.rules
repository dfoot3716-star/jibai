rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: tasks
    // Document ID: {taskId}
    // Fields:
    //   - id: string (required)
    //   - text: string (required, max 500)
    //   - priority: string (required, enum)
    //   - completed: bool (required)
    //   - createdAt: number (required)
    //   - uid: string (required, immutable)
    //
    // Collection: diaries
    // Document ID: {diaryId}
    // Fields:
    //   - id: string (required)
    //   - date: string (required, YYYY-MM-DD)
    //   - content: string (required, max 5000)
    //   - chatHistory: list (required, max 50 items)
    //   - uid: string (required, immutable)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isDocOwner() {
      return isOwner(resource.data.uid);
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function isValidTask(data) {
      return data.keys().hasAll(['id', 'text', 'priority', 'completed', 'createdAt', 'uid']) &&
             data.text is string && data.text.size() <= 500 &&
             data.priority in ['IMPORTANT_URGENT', 'IMPORTANT_NOT_URGENT', 'URGENT_NOT_IMPORTANT', 'CASUAL'] &&
             data.completed is bool &&
             data.createdAt is number &&
             data.uid == request.auth.uid;
    }

    function isValidDiary(data) {
      return data.keys().hasAll(['id', 'date', 'content', 'chatHistory', 'uid']) &&
             data.date is string && data.date.matches('^\\d{4}-\\d{2}-\\d{2}$') &&
             data.content is string && data.content.size() <= 5000 &&
             data.chatHistory is list && data.chatHistory.size() <= 50 &&
             data.uid == request.auth.uid;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /tasks/{taskId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidTask(request.resource.data) && uidUnchanged();
      allow update: if isDocOwner() && isValidTask(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner();
    }

    match /diaries/{diaryId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidDiary(request.resource.data) && uidUnchanged();
      allow update: if isDocOwner() && isValidDiary(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner();
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId);
    }
  }
}
