// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: tasks
// Document ID: auto-generated or custom string
// Fields:
//   - id: string (required) - unique task ID
//   - text: string (required) - task description
//   - completed: boolean (required) - completion status
//   - createdAt: number (required) - timestamp
//   - uid: string (required) - owner's user ID
//   - category: string (required) - WORK, HEALTH, PERSONAL, LEARNING
//   - pos: map (optional) - { x: number, y: number }
//
// Collection: diaries
// Document ID: auto-generated or custom string
// Fields:
//   - id: string (required) - unique diary ID
//   - date: string (required) - YYYY-MM-DD
//   - content: string (required) - diary text
//   - moodColor: string (optional) - hex color
//   - chatHistory: array of objects (required) - { role: string, text: string }
//   - uid: string (required) - owner's user ID
//
// Collection: users
// Document ID: user UID
// Fields:
//   - uid: string (required) - user ID
//   - displayName: string (optional) - user's name
//   - photoURL: string (optional) - avatar URL
//   - email: string (optional) - user's email
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidTask(data) {
      return data.text is string && data.text.size() > 0 && data.text.size() < 1000 &&
             data.category in ['WORK', 'HEALTH', 'PERSONAL', 'LEARNING'] &&
             data.completed is bool &&
             data.createdAt is number &&
             data.uid is string && data.uid == request.auth.uid;
    }

    function isValidDiary(data) {
      return data.date is string && data.date.matches("^\\d{4}-\\d{2}-\\d{2}$") &&
             data.content is string && data.content.size() < 10000 &&
             data.chatHistory is list &&
             data.uid is string && data.uid == request.auth.uid;
    }

    function isValidUser(data) {
      return data.uid is string && data.uid == request.auth.uid &&
             (!('email' in data) || data.email is string) &&
             (!('displayName' in data) || data.displayName is string) &&
             (!('photoURL' in data) || data.photoURL is string);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /tasks/{taskId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.uid == request.auth.uid);
      allow create: if isAuthenticated() && hasRequiredFields(['id', 'text', 'category', 'completed', 'createdAt', 'uid']) && isValidTask(request.resource.data);
      allow update: if isAuthenticated() && isDocOwner() && uidNotModified() && isValidTask(request.resource.data);
      allow delete: if isAuthenticated() && isDocOwner();
    }

    match /diaries/{diaryId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.uid == request.auth.uid);
      allow create: if isAuthenticated() && hasRequiredFields(['id', 'date', 'content', 'chatHistory', 'uid']) && isValidDiary(request.resource.data);
      allow update: if isAuthenticated() && isDocOwner() && uidNotModified() && isValidDiary(request.resource.data);
      allow delete: if isAuthenticated() && isDocOwner();
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
    }
  }
}
